{
  "manifest_version": 3,
  "name": "Smart Autobidder Assistant",
  "version": "1.0.0",
  "description": "Capture job pages, generate application drafts, and autofill basic fields.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Autobidder Assistant"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/applypilot-logo.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
